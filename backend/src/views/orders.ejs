<!DOCTYPE html>
<html>
<head>

<title>Orders</title>

<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/orders.css">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

</head>

<body>

<div class="layout">

<%- include('./partials/sidebar', { activePage: 'orders', user: user }) %>

<div class="main">

<h2>Purchase Orders</h2>

<div style="margin-bottom:20px">
<button class="filter-btn active" onclick="filterOrders('', this)">All</button>
<button class="filter-btn" onclick="filterOrders('Pending', this)">Pending</button>
<button class="filter-btn" onclick="filterOrders('Partially Delivered', this)">Partially Delivered</button>
<button class="filter-btn" onclick="filterOrders('Delivered', this)">Delivered</button>
<button class="filter-btn" onclick="filterOrders('Cancelled', this)">Cancelled</button>

</div>


<table class="billing-table">

<thead>
<tr>
<th>PO ID</th>
<th>Supplier</th>
<th>Medicines</th>
<th>Date</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>

<tbody id="ordersTable"></tbody>

</table>

<hr>

<div id="orderDetails"></div>

</div>

</div>

<script src="/js/orders.js"></script>

</body>
</html>