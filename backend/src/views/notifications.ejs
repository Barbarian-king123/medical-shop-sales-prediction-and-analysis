<!DOCTYPE html>
<html>
<head>
    <title>Notifications</title>

    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/notifications.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

<div class="layout">

    <%- include('./partials/sidebar', { activePage: 'notifications', user: user }) %>

    <div class="main">

        <h2>Notifications</h2>

        <!-- ACTION BUTTONS -->
        <div class="notification-actions">

            <button id="checkExpiry">
                <i class="fa-solid fa-clock"></i> Check Expiry
            </button>

            <button id="checkStock">
                <i class="fa-solid fa-box"></i> Check Low Stock
            </button>

            <button id="clearAllNotifications" class="danger-btn">
                <i class="fa-solid fa-trash"></i> Clear All
            </button>

        </div>

        <!-- 🔥 TAB BUTTONS -->
        <div class="notification-tabs">
            <button class="filter-btn active" id="showLowStock">
                Low Stock
            </button>

            <button class="filter-btn" id="showExpiry">
                Expiry
            </button>
        </div>

        <!-- =============================== -->
        <!-- 🔵 LOW STOCK TABLE -->
        <!-- =============================== -->
        <div id="lowStockSection">

            <div class="notification-section">

                <h3>Low Stock Alerts</h3>

                <table class="notification-table">

                    <thead>
                        <tr>
                            <th>Medicine</th>
                            <th>Current Stock</th>
                            <th>Reorder Point</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="lowStockBody"></tbody>

                </table>

            </div>

        </div>

        <!-- =============================== -->
        <!-- 🔴 EXPIRY TABLE -->
        <!-- =============================== -->
        <div id="expirySection" style="display:none;">

            <div class="notification-section">

                <h3>Expiry Alerts</h3>

                <table class="notification-table">

                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Medicine</th>
                            <th>Batch No</th>
                            <th>Expiry Date</th>
                            <th>Created At</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="expiryBody"></tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<script src="/js/notifications.js"></script>
</body>
</html>